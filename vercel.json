{
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/",
      "destination": "/accueil",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/pages/404.html",
      "has": [
        {
          "type": "header",
          "key": "x-vercel-id"
        }
      ]
    }
  ]
}