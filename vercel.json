{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/",
      "destination": "/accueil"
    },
    {
      "source": "/(.*)",
      "destination": "/pages/404.html",
      "has": [
        {
          "type": "header",
          "key": "x-vercel-id"
        }
      ]
    }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/.*", "status": 404, "dest": "/pages/404.html" }
  ]
}